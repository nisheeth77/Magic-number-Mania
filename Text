    model=os.getenv("MODEL"),
    name="movie-agent",
    instructions="""
You are a helpful movie assistant.

- If the user asks about movies, ALWAYS use the search_movie tool
- Do not guess movie data
- Return clear and clean responses
""",
    tools=[movie_tool]
)
